---
// #post
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { format } from 'date-fns';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const isDev = import.meta.env.DEV;
---

<Layout
  title={post.data.title}
  tag={post.data.tags[0]}
  description={post.data.description}
  ogImage={post.data.ogImage}
>
  <article class="post">
    <header>
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="description">{post.data.description}</p>}
      <div class="small">
        <time datetime={post.data.pubDate.toISOString()}>
          Planted {format(post.data.pubDate, 'MMM yyyy')}
        </time>
        {post.data.tendDate ?
          <span class="tertiary">· · ·</span>
          <time datetime={post.data.tendDate.toISOString()}>
            Tended {format(post.data.tendDate, 'MMM yyyy')}
          </time>
          :
          null
        }
        {isDev && (
          <>
            <span class="tertiary">· · ·</span>
            <a id="edit-toggle" href="#edit" class="small">Edit</a>
            <button id="save-btn" type="button" disabled style="display: none;">Save <kbd>⌃S</kbd></button>
            <span id="save-status"></span>
          </>
        )}
      </div>
    </header>
    <div class="content-wrapper">
      <div class="content" id="view-mode">
        <Content />
      </div>
      {isDev && (
        <div class="editor" id="edit-mode" style="display: none;">
          <textarea id="editor-content" rows="30" placeholder="Loading..."></textarea>
        </div>
      )}
    </div>
  </article>
</Layout>

{isDev && (
  <script define:vars={{ slug: post.slug }}>
    const textarea = document.getElementById('editor-content');
    const saveBtn = document.getElementById('save-btn');
    const status = document.getElementById('save-status');
    const editToggle = document.getElementById('edit-toggle');
    const viewMode = document.getElementById('view-mode');
    const editMode = document.getElementById('edit-mode');

    let isDirty = false;
    let contentLoaded = false;

    function isEditHash() {
      return window.location.hash === '#edit';
    }

    async function loadContent() {
      if (contentLoaded) return;
      status.textContent = 'Loading...';
      try {
        const res = await fetch(`/api/read-post?slug=${encodeURIComponent(slug)}`);
        const data = await res.json();
        if (data.content) {
          textarea.value = data.content;
          textarea.placeholder = '';
          saveBtn.disabled = false;
          status.textContent = '';
          contentLoaded = true;
        } else {
          status.textContent = `Error: ${data.error || 'Failed to load'}`;
        }
      } catch (err) {
        status.textContent = `Error: ${err.message}`;
      }
    }

    function updateMode() {
      const editing = isEditHash();
      viewMode.style.display = editing ? 'none' : '';
      editMode.style.display = editing ? '' : 'none';
      editToggle.textContent = editing ? 'View' : 'Edit';
      editToggle.href = editing ? window.location.pathname : '#edit';
      saveBtn.style.display = editing ? '' : 'none';

      if (editing) {
        loadContent();
      }
    }

    // Handle hash changes (back/forward, clicking toggle)
    window.addEventListener('hashchange', updateMode);

    // Initial state
    updateMode();

    textarea.addEventListener('input', () => {
      isDirty = true;
    });

    window.addEventListener('beforeunload', (e) => {
      if (isDirty) e.preventDefault();
    });

    async function savePost() {
      status.textContent = 'Saving...';
      try {
        const res = await fetch('/api/save-post', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, content: textarea.value })
        });
        const data = await res.json();
        if (data.success) {
          isDirty = false;
          status.textContent = 'Saved!';
        } else {
          status.textContent = `Error: ${data.error}`;
        }
      } catch (err) {
        status.textContent = `Error: ${err.message}`;
      }
    }

    saveBtn.addEventListener('click', savePost);

    // Cmd/Ctrl+S to save
    textarea.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.key === 's') {
        e.preventDefault();
        savePost();
      }
    });
  </script>
)}

<script>
  document.querySelectorAll('pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.textContent = 'Copy';
    btn.className = 'copy-btn';
    btn.setAttribute('aria-label', 'Copy code to clipboard');

    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      const text = code ? code.innerText : pre.innerText;
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });

    pre.style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style is:global>
  pre {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: calc(var(--base) * 2);
    right: calc(var(--base) * 2);
    padding: 2px 8px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.6;
    cursor: pointer;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: #fff;
    color: var(--mid);
    opacity: 0;
    transition: opacity 0.15s;
  }

  pre:hover .copy-btn {
    opacity: 1;
  }

  .copy-btn:hover {
    background: var(--warm);
    color: var(--text);
  }
</style>

<style>
  .editor {
    width: 100%;
  }

  .editor textarea {
    width: 100%;
    min-height: 60vh;
    padding: 1rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    border: 1px solid var(--border);
    border-radius: 4px;
    resize: vertical;
    background: var(--surface);
    color: var(--text);
  }

  #save-btn {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    cursor: pointer;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
    color: var(--text);
    padding: 0 0.4rem;
  }

  #save-btn:hover {
    background: var(--border);
  }

  #save-btn kbd {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    opacity: 0.6;
  }

  #save-status {
    font-size: 0.875rem;
    color: var(--secondary);
  }
</style>
